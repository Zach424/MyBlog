{
  "name": "zach424-myblog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:unit && npm run typecheck && npm run build && npm run test:app",
    "test:unit": "node --experimental-strip-types --test tests/content-contract.test.mjs tests/search.test.mjs tests/discovery.test.mjs tests/cms-oauth.test.mjs tests/studio-config.test.mjs tests/obsidian-publishing.test.mjs tests/deployment-tools.test.mjs",
    "test:app": "node scripts/test-production.mjs tests/rendered-html.test.mjs tests/quality-gates.test.mjs",
    "audit": "node scripts/test-production.mjs tests/quality-gates.test.mjs",
    "check": "npm run lint && npm test",
    "release:check": "node scripts/check-release-config.mjs && npm run check && npm audit --omit=dev --audit-level=high",
    "content:publish": "node --experimental-strip-types scripts/publish-note.mjs",
    "production:smoke": "node scripts/smoke-production.mjs",
    "migration:status": "node scripts/check-migration-status.mjs",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern .vercel",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "github-slugger": "2.0.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "type": "module"
}
